# =============================================================================
# Azure Boards Manager — Plantilla de configuración de variables
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copia este fichero y renómbralo como ".env" (sin el .example)
#   2. Rellena los valores marcados como OBLIGATORIO
#   3. El fichero .env NUNCA debe subirse a GitHub (ya está en .gitignore)
#
# Para más información sobre cada variable, consulta el README.md
# =============================================================================


# -----------------------------------------------------------------------------
# AZURE DEVOPS — Conexión con tu organización
# -----------------------------------------------------------------------------

# URL de tu organización en Azure DevOps (OBLIGATORIO)
# Ejemplo: https://dev.azure.com/mi-empresa
AZURE_DEVOPS_ORG_URL=

# Nombre exacto del proyecto en Azure DevOps (OBLIGATORIO)
# Lo encuentras en la URL: https://dev.azure.com/<org>/<proyecto>
AZURE_DEVOPS_PROJECT=

# Personal Access Token con permisos de lectura en Work Items (opcional aquí)
# RECOMENDADO: déjalo vacío y el sistema te lo pedirá la primera vez
# que ejecutes el proyecto y lo guardará de forma segura automáticamente.
# Si lo rellenas aquí, funciona pero es menos seguro.
AZURE_DEVOPS_PAT=

# IDs de las tarjetas raíz a procesar, separadas por comas (opcional)
# Si lo dejas vacío, el sistema te pedirá el ID al ejecutar.
# Ejemplo: AZURE_ROOT_IDS=12120,13450,14200
AZURE_ROOT_IDS=

# Campos adicionales de Azure DevOps a extraer (opcional)
# Si lo dejas vacío, se usarán los campos predeterminados del sistema.
# Ejemplo: AZURE_FIELDS=Custom.Area,Custom.Responsable,Custom.Estado
AZURE_FIELDS=


# -----------------------------------------------------------------------------
# SQL SERVER — Conexión con la base de datos
# -----------------------------------------------------------------------------

# Nombre del servidor o instancia SQL Server (OBLIGATORIO)
# Ejemplos: mi-servidor, localhost\SQLEXPRESS, 192.168.1.10
SQL_SERVER=

# Nombre de la base de datos de destino (OBLIGATORIO)
SQL_DATABASE=

# Tiempo máximo (en segundos) para probar Windows Authentication
# Valor recomendado: 3
SQL_WINDOWS_AUTH_TIMEOUT=3

# Credenciales SQL Server (opcional)
# RECOMENDADO: déjalos vacíos. El sistema intentará Windows Authentication
# automáticamente. Si no está disponible, te pedirá las credenciales
# la primera vez y las guardará de forma segura.
# Si los rellenas aquí, funciona pero es menos seguro.
SQL_USER=
SQL_PASSWORD=


# -----------------------------------------------------------------------------
# SQL SERVER — Tablas y procedimiento almacenado de destino
# -----------------------------------------------------------------------------

# Esquema y tabla donde se cargarán las tarjetas
SQL_SCHEMA=raw
SQL_TABLE=azuTarjetas

# Procedimiento almacenado que se ejecutará tras la carga
SQL_STORED_PROCEDURE=dbo.SP_AzureModelo

# Esquema y tabla donde se guardarán los logs de ejecución
SQL_LOG_SCHEMA=raw
SQL_LOG_TABLE=LogsPython
